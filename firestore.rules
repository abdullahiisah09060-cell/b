rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 6.1 MANDATORY ADMIN IDENTITY: Single source of truth
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'liger4683@gmail.com';
    }
    
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if request.auth != null && (isOwner(uid) || isAdmin());
      // Prevent role escalation: users can't set their own role to admin
      allow create: if request.auth != null && request.resource.data.role != 'admin';
      allow update: if isAdmin() || (isOwner(uid) && request.resource.data.role == resource.data.role);
    }

    match /admin_only_logs/{doc} {
      allow read, write: if isAdmin();
    }

    // Withdrawal Codes: Paystack-only verification
    match /codes/{codeId} {
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      // Create only allowed via system (Paystack logic)
      allow create: if request.auth != null; 
      allow update: if isAdmin() || (isOwner(resource.data.uid) && request.resource.data.used == true);
    }

    // Global Settings
    match /settings/global {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Generic protections for all other collections
    match /{collection}/{doc} {
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow write: if isAdmin() || (request.auth != null && request.resource.data.uid == request.auth.uid);
    }
  }
}
