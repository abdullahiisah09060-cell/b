rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. GLOBAL HELPERS
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "liger4683@gmail.com";
    }

    // 2. USERS COLLECTION
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated(); // Controlled by auth.js logic
      allow update: if isOwner(userId) || isAdmin();
    }

    // 3. TRANSACTIONS & FINANCIALS
    match /transactions/{txId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated(); // Needs to be written from client on deposit/withdraw
      allow update, delete: if isAdmin();
    }

    match /deposits/{depId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    match /withdrawals/{wId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    // 4. INVESTMENT LOGIC
    match /investments/{invId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isAdmin() || resource.data.uid == request.auth.uid);
    }

    // 5. SECURITY CODES (WDC)
    match /codes/{codeId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    // 6. SUPPORT SYSTEM
    match /support/{userId} {
      allow read, write: if isAdmin() || isOwner(userId);
      
      match /messages/{msgId} {
        allow read, write: if isAdmin() || isOwner(userId);
      }
    }

    // 7. KYC PORTAL
    match /kyc/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) || isAdmin();
    }

    // 8. SYSTEM DATA (Notifications, Broadcasts, Settings)
    match /notifications/{id} {
      allow read, update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create, delete: if isAdmin();
    }

    match /broadcasts/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
