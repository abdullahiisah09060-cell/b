rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core Helpers
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }
    function isAdmin() { return isAuth() && request.auth.token.email == "liger4683@gmail.com"; }

    // User Records
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isAuth(); // Document checked for duplicates in JS
      allow update: if isAdmin() || (isOwner(uid) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['balance', 'role', 'email']));
    }

    // Transactions / Deposits / Withdrawals
    match /transactions/{id} {
      allow read: if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }
    
    match /deposits/{id} {
      allow read: if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    match /withdrawals/{id} {
      allow read: if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // Investments
    match /investments/{id} {
      allow read: if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
      allow create: if isAuth();
      allow update: if isAuth() && (isAdmin() || resource.data.uid == request.auth.uid);
    }

    // Validator Codes
    match /codes/{id} {
      allow read: if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
      allow create: if isAuth();
      allow update: if isAuth();
    }

    // KYC
    match /kyc/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // Support
    match /support/{uid} {
      allow read, write: if isAdmin() || isOwner(uid);
      match /messages/{mid} {
        allow read, write: if isAdmin() || isOwner(uid);
      }
    }

    // System Config
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{id} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid;
      allow update: if isAuth() && resource.data.uid == request.auth.uid;
      allow create: if isAdmin();
      allow delete: if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
    }
  }
}
