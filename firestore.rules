rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ----------------------------------------------------
    // SECURITY KERNEL
    // ----------------------------------------------------
    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }
    function isAdmin() { return isAuthenticated() && request.auth.token.email == "liger4683@gmail.com"; }

    // ----------------------------------------------------
    // COLLECTION RULES
    // ----------------------------------------------------

    // 1. Users: Only owner can read/update (excluding role field). Admin reads all.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated();
      allow update: if isOwner(userId) || isAdmin();
    }

    // 2. Financials: Locked for deletion. Owner reads their own. Admin writes status.
    match /transactions/{id} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated(); 
      allow update, delete: if isAdmin();
    }

    match /deposits/{id} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /withdrawals/{id} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // 3. Investments: Atomic claims handled in JS, rules allow sync.
    match /investments/{id} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isAdmin() || resource.data.uid == request.auth.uid);
    }

    // 4. Validator Codes: Codes are linked to UID.
    match /codes/{id} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    // 5. KYC: Document storage paths.
    match /kyc/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) || isAdmin();
    }

    // 6. Support System: Multi-pane structure.
    match /support/{userId} {
      allow read, write: if isAdmin() || isOwner(userId);
      match /messages/{msgId} {
        allow read, write: if isAdmin() || isOwner(userId);
      }
    }

    // 7. System & Notifications
    match /notifications/{id} {
      allow read, update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create, delete: if isAdmin();
    }

    match /broadcasts/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
